{
  "expo": {
    "name": "Global Space",
    "slug": "andriod-ios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "andriodios",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yuvaraj.globalspace"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.yuvaraj.globalspace"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A",
          "dark": {
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1decc82a-248c-4668-8dbe-5b3c57e61e4b"
      },
      "googleClientId": "569315023852-n4t0n0goe3ghj6s7sqj6tu6hafqr8m48.apps.googleusercontent.com",
      "googleWebClientId": "569315023852-lrseul03f890sjlls0se2e51mtu4e8ks.apps.googleusercontent.com",
      "googleIosClientId": "569315023852-d15n28d9lnrvimvqq6dbb4311o855l3e.apps.googleusercontent.com"
    }
  }
}
